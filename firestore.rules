rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Public leaderboard.
    // Reads open to everyone; writes require auth + uid match.
    match /leaderboard/{entryId} {
      allow read: if true;

      allow create: if isValidEntry(request.resource.data) &&
                       request.auth != null &&
                       request.resource.data.uid == request.auth.uid;

      allow update, delete: if false;
    }

    // Nickname registry — first uid to claim a nickname owns it forever.
    // Doc id is the nickname itself (lowercased + trimmed by the client).
    // Stops impersonators from posting under someone else's name.
    match /nicknames/{name} {
      allow read: if true;

      // Create: name not yet taken; payload is just {uid, createdAt}; uid matches caller
      allow create: if request.auth != null
                    && request.resource.data.keys().hasOnly(['uid', 'createdAt'])
                    && request.resource.data.uid is string
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.createdAt == request.time
                    && name.size() >= 1
                    && name.size() <= 24;

      // Updates only allowed by the owner (so we could allow re-claim if we wanted)
      allow update: if request.auth != null
                    && resource.data.uid == request.auth.uid
                    && request.resource.data.uid == request.auth.uid;

      allow delete: if false;
    }

    // Default deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }

  function isValidEntry(d) {
    return d.keys().hasOnly(['name', 'score', 'level', 'uid', 'createdAt'])
      && d.name is string
      && d.name.size() >= 1
      && d.name.size() <= 12
      && d.score is int
      && d.score >= 0
      && d.score <= 100000000
      && d.level is int
      && d.level >= 1
      && d.level <= 999
      && d.uid is string
      && d.uid.size() >= 10
      && d.createdAt == request.time;
  }
}
