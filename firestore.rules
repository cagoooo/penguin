rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Public leaderboard for the penguin game.
    // Reads are open to everyone; writes require an authenticated user (we use
    // anonymous auth on the client) and the uid in the doc must match the
    // caller's auth.uid. This prevents pure-curl spam without forcing a login.
    match /leaderboard/{entryId} {
      allow read: if true;

      allow create: if isValidEntry(request.resource.data) &&
                       request.auth != null &&
                       request.resource.data.uid == request.auth.uid;

      // Entries are append-only — no updates / deletes from the client.
      allow update, delete: if false;
    }

    // Default deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }

  function isValidEntry(d) {
    return d.keys().hasOnly(['name', 'score', 'level', 'uid', 'createdAt'])
      && d.name is string
      && d.name.size() >= 1
      && d.name.size() <= 12
      && d.score is int
      && d.score >= 0
      && d.score <= 100000000
      && d.level is int
      && d.level >= 1
      && d.level <= 999
      && d.uid is string
      && d.uid.size() >= 10
      && d.createdAt == request.time;
  }
}
